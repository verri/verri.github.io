author = {Gao, Xubo and Zheng, Qiusheng and Verri, Filipe A. N. and Rodrigues, Rafael D. and Zhao, Liang},
title = {Particle Competition for Multilayer Network Community Detection},
year = {2019},
isbn = {9781450366007},

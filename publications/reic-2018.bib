@article{REIC2018, title={Classificação de Alto Nível Baseada em Entropia da Rede}, volume={16}, url={https://sol.sbc.org.br/journals/index.php/reic/article/view/1812}, DOI={10.5753/reic.2018.1812}, abstractNote={&amp;lt;p&amp;gt;Técnicas tradicionais de classificação que baseiam-se apenas em características físicas dos dados são chamadas de classificação de baixo nível. Se consideram, além dos atributos físicos, o padrão de formação, são denominadas técnicas de classificação de alto nível. Apresenta-se aqui o projeto de iniciação científica que propõe o desenvolvimento de uma nova técnica de classificação de alto nível baseada na medição das entropias da rede antes e depois da inserção de um item a ser classificado. Este item é classificado como pertencente à classe que resultar o maior aumento nas medições. O método pode classificar os dados por sua similaridade e padrão de formação. Em resumo, esta técnica calcula a importância do dado para cada uma das classes.&amp;lt;/p&amp;gt;}, number={1}, journal={Revista Eletrônica de Iniciação Científica em Computação}, author={Zhao, Liang and Neto, Filipe}, year={2018}, month={jan.} }
